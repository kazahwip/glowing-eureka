NODE_ENV=production

TEAMBOT_TOKEN=
SERVICEBOT_TOKEN=

ADMIN_TELEGRAM_IDS=
ADMIN_AUDIT_CHAT_ID=
SUPPORT_NOTIFY_IDS=

DATABASE_PATH=./data/awake.sqlite

TEAMBOT_ASSETS_DIR=./assets/teambot
SERVICEBOT_ASSETS_DIR=./assets/servicebot
WEBAPP_BASE_URL=
# Set your public HTTPS domain to enable the Honey Bunny Mini App, for example:
# WEBAPP_BASE_URL=https://your-domain.tld/webapp
WEBAPP_PORT=3000
WEBAPP_SECRET_MODE=telegram_init_data

PROJECT_START_DATE=2026-04-06
PROJECT_PAYOUT_PERCENT=75
DEFAULT_TRANSFER_DETAILS=2200701789834873 Т-банк

# Optional legacy mode: start only one bot via bothost launcher.
# If BOT_INSTANCE is empty, bothost launcher starts both bots together.
# Allowed values: teambot or servicebot
BOT_INSTANCE=
