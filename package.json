{
  "name": "awake-bots",
  "version": "1.0.0",
  "description": "Система из двух Telegram-ботов на Node.js + TypeScript + Telegraf",
  "main": "bothost.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:team": "tsx watch src/apps/teambot.ts",
    "dev:service": "tsx watch src/apps/servicebot.ts",
    "start": "node bothost.js",
    "start:bothost": "node bothost.js",
    "start:team": "node teambot.js",
    "start:service": "node servicebot.js",
    "db:init": "tsx src/db/init.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "telegram",
    "telegraf",
    "typescript",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.16.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
